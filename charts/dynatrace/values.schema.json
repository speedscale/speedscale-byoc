{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Speedscale BYOC OTel Collector → Dynatrace chart values",
  "type": "object",
  "additionalProperties": false,
  "required": ["dynatrace"],
  "properties": {
    "dynatrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["endpoint", "tokenSecret"],
      "properties": {
        "endpoint": {
          "type": "string",
          "format": "uri",
          "minLength": 1,
          "description": "Dynatrace OTLP base URL, e.g. https://<env-id>.live.dynatrace.com/api/v2/otlp"
        },
        "tokenSecret": {
          "type": "string",
          "minLength": 1,
          "description": "K8s Secret name holding the API token (key: apiToken)"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "otelCollector": {
          "type": "string",
          "minLength": 1,
          "description": "OTel Collector image (otlphttp is in both core and contrib distributions)"
        }
      }
    }
  }
}
