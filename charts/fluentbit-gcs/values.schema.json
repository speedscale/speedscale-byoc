{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Speedscale BYOC OTel Collector → GCS chart values",
  "type": "object",
  "additionalProperties": false,
  "required": ["gcs"],
  "properties": {
    "gcs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bucket", "region"],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1,
          "description": "GCS bucket name (required) — must exist before installing"
        },
        "region": {
          "type": "string",
          "minLength": 1,
          "description": "GCS region (e.g. us-central1)"
        },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "GCS XML/Interop endpoint URL"
        },
        "credentialsSecret": {
          "type": "string",
          "description": "K8s Secret name holding HMAC accessKeyId + secretAccessKey"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "otelCollector": {
          "type": "string",
          "minLength": 1,
          "description": "Must be opentelemetry-collector-contrib (awss3 is contrib-only)"
        }
      }
    }
  }
}
