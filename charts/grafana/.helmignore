# Patterns to ignore when building packages.
# This follows the same rules as .gitignore.

# Don't bundle examples or changelog — they're for GitHub/docs browsing only.
examples/
CHANGELOG.md

# files/ contains dashboard JSON that IS intentionally bundled for Grafana
# provisioning (ConfigMap). Do NOT add files/ here.

# OS and editor noise
.DS_Store
.idea/
*.swp
*.swo
